<h1>Create New Note</h1>

<!-- Inline error display -->
<% if (error && error.trim() !== '') { %>
  <div class="alert alert-danger mt-3"><%= error %></div>
<% } %>


<form action="/notes" method="POST">
  <input class="form-control mb-2" name="title" placeholder="Title" value="<%= title || '' %>" required />
  <textarea class="form-control mb-2" name="description" rows="5" placeholder="Description" required><%= description || '' %></textarea>

  <button class="btn btn-outline-success">Create Note</button>
  <a href="/notes" class="btn btn-outline-danger"
    onclick="return confirm('Are you sure you want to cancel editing? Changes will not be saved.');">
    Cancel
  </a>
</form>


