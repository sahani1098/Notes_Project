<h1>Edit Note</h1>
<form action="/notes/<%= note._id %>?_method=PUT" method="POST">
    <div class="mb-3">
        <label for="title" class="form-label">Title</label>
        <input type="text" class="form-control" id="title" name="title" value="<%= note.title %>" required>
    </div>

    <div class="mb-3">
        <label for="description" class="form-label">Description</label>
        <textarea class="form-control" id="description" name="description" rows="5"
            required><%= note.description %></textarea>
    </div>

    <div class="d-flex gap-2">
        <!-- ✅ Submit button -->
        <button type="submit" class="btn btn-outline-success"
            onclick="return confirm('Are you sure you want to update this note?');">
            Update Note
        </button>

        <!-- ✅ Cancel button with confirmation -->
        <a href="/notes" class="btn btn-outline-danger"
            onclick="return confirm('Are you sure you want to cancel editing? Changes will not be saved.');">
            Cancel
        </a>
    </div>
</form>