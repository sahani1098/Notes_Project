<h1>Your Notes</h1>
<a href="/notes/new" class="btn btn-primary mb-3">Create New Note</a>
<ul class="list-group">
  <% notes.forEach(note=> { %>
    <li class="list-group-item d-flex justify-content-between">
      <strong><a href="/notes/<%= note._id %>">
          <%= note.title %>
        </a></strong>
      <div class="d-flex align-items-center">
        <div class="small text-muted mx-2">
          <%= note.formattedDate %>
        </div>
        <a href="/notes/<%= note._id %>/edit" class="btn btn-sm btn-warning mx-2">Edit</a>
        <form action="/notes/<%= note._id %>?_method=DELETE" method="POST" style="display:inline;">
          <button class="btn btn-sm btn-danger mx-2">Delete</button>
        </form>
      </div>
    </li>
    <% }) %>
</ul>